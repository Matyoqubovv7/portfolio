#  Xudoyshukur Matyoqubov — Portfolio Environment Variables
# ─────────────────────────────────────────────────────────────

# Copy this file to server/.env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas URI (optional — falls back to JSON storage)
# Get yours at: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/portfolio

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
